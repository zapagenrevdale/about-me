NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Generate a hash with `pnpm diary:hash`; never store the raw diary password.
DIARY_PASSWORD_HASH=
DIARY_SESSION_SECRET=replace-with-at-least-32-random-characters

# Local file mode works without running a Turso dev server.
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# To use Turso's local libSQL server instead, run `pnpm db:dev` and use:
# TURSO_DATABASE_URL=http://127.0.0.1:8080
# TURSO_AUTH_TOKEN=

# Production Turso:
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-token
